<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link
      href="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-gray-100 dark:bg-gray-800 dark:text-white h-screen w-screen flex items-center justify-center px-4">
    <form action="/user/register" method="post" class="w-full max-w-sm rounded-lg border border-gray-200 bg-white p-8 shadow-lg dark:border-gray-700 dark:bg-gray-900">
        <div class="mb-6 flex items-center justify-center gap-3">
          <svg class="h-7 w-7 text-blue-600 dark:text-blue-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
            <path d="M9 7V2.221a2 2 0 0 0-.5.365L4.586 6.5a2 2 0 0 0-.365.5H9Z"/>
            <path fill-rule="evenodd" d="M11 7V2h7a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V9h5a2 2 0 0 0 2-2Zm4.707 5.707a1 1 0 0 0-1.414-1.414L11 14.586l-1.293-1.293a1 1 0 0 0-1.414 1.414l2 2a1 1 0 0 0 1.414 0l4-4Z" clip-rule="evenodd"/>
          </svg>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">File Uploader</h1>
        </div>
        <div class="mb-5">
          <label
            for="username"
            class="block mb-2.5 text-sm font-bold text-gray-900 dark:text-white"
            >Username</label
          >
          <input
            type="text"
            id="username"
            class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 shadow-xs focus:border-blue-500 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:placeholder-gray-400"
            placeholder="John"
            name="username"
            required
          />
        </div>
      <div class="mb-6">
        <label for="email" class="block mb-2.5 text-sm font-bold text-gray-900 dark:text-white"
          >Email address</label
        >
        <input
          type="email"
          id="email"
          class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 shadow-xs focus:border-blue-500 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:placeholder-gray-400"
          placeholder="john.doe@company.com"
          name="email"
          required
        />
      </div>
      <div class="mb-6">
        <label
          for="password"
          class="block mb-2.5 text-sm font-bold text-gray-900 dark:text-white"
          >Password</label
        >
        <input
          type="password"
          id="password"
          class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 shadow-xs focus:border-blue-500 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:placeholder-gray-400"
          placeholder="•••••••••"
          name="password"
          required
        />
      </div>
      <button
        type="submit"
        class="w-full rounded-lg border border-transparent bg-blue-600 px-4 py-2.5 text-sm font-medium leading-5 text-white shadow-xs hover:bg-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-300"
      >
        Submit
      </button>
      <p class="mt-4 text-sm text-center text-gray-700 dark:text-gray-200">
        Already have an account? <a href="/user/login" class="text-blue-600 hover:underline">Login here</a>
      </p>
    </form>

    <script src="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.js"></script>
  </body>
</html>
