<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com"></script>

    <title>File Upload</title>
  </head>
  <body>
    <main class="p-4 bg-gray-100 dark:bg-gray-900 min-h-screen w-screen">
      <div class="max-w-6xl mx-auto">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 mb-6">
          <div>
            <h1 class="text-3xl font-semibold text-gray-900 dark:text-white">My Files</h1>
            <p class="mt-2 text-gray-600 dark:text-gray-300">Only your uploaded files are shown here.</p>
          </div>
          <div class="flex items-center gap-3">
            <a href="/user/logout" class="bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded-lg transition">Logout</a>
            <button
              id="uploadBtn"
              class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg transition"
            >
              Upload File
            </button>
          </div>
        </div>

        <% if (files && files.length > 0) { %>
        <div class="mb-4 flex flex-col md:flex-row gap-3 md:items-center md:justify-between">
          <div class="relative w-full md:max-w-md">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
              <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z" />
              </svg>
            </div>
            <input
              id="fileSearchInput"
              type="search"
              list="fileSuggestions"
              placeholder="Search files..."
              autocomplete="off"
              class="block w-full rounded-lg border border-gray-300 bg-white py-2.5 pl-10 pr-4 text-sm text-gray-900 focus:border-blue-500 focus:ring-blue-500 dark:border-gray-700 dark:bg-gray-800 dark:text-white dark:placeholder-gray-400"
            />
            <datalist id="fileSuggestions">
              <% files.forEach(function(file) { %>
                <option value="<%= file.originalname %>"></option>
              <% }) %>
            </datalist>
          </div>

          <div class="flex items-center gap-2">
            <label for="fileSortSelect" class="text-sm font-medium text-gray-700 dark:text-gray-300">Sort by</label>
            <select
              id="fileSortSelect"
              class="rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm text-gray-900 focus:border-blue-500 focus:ring-blue-500 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
            >
              <option value="latest">Latest upload</option>
              <option value="name">Alphabetical order</option>
              <option value="size">Size: low to high</option>
            </select>
          </div>
        </div>

        <div class="overflow-x-auto bg-white dark:bg-gray-800 shadow rounded-lg">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-900">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Filename</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Size</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Uploaded</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody id="filesTableBody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
              <% files.forEach(function(file, index) { %>
              <tr data-file-row data-name="<%= file.originalname %>" data-size="<%= file.size %>" data-index="<%= index %>">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white"><%= file.originalname %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-300"><%= file.mimetype %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-300"><%= (file.size / 1024).toFixed(2) %> KB</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-300"><%= new Date(file.createdAt).toLocaleString() %></td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
                  <a href="/download/<%= file._id %>" class="inline-flex items-center px-3 py-1.5 bg-green-600 text-white rounded-lg hover:bg-green-700">Download</a>
                  <button onclick="deleteFile('<%= file._id %>')" class="inline-flex items-center px-3 py-1.5 bg-red-600 text-white rounded-lg hover:bg-red-700">Delete</button>
                </td>
              </tr>
              <% }) %>
              <tr id="noSearchResultsRow" class="hidden">
                <td colspan="5" class="px-6 py-6 text-center text-sm text-gray-500 dark:text-gray-300">
                  No files match your search.
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div class="rounded-lg border border-dashed border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-8 text-center">
          <p class="text-gray-600 dark:text-gray-300">You have no uploaded files yet. Use the Upload File button to add your first file.</p>
        </div>
        <% } %>

        <!-- Modal Backdrop -->
        <div id="modalBackdrop" class="hidden fixed top-0 left-0 h-screen w-screen flex items-center justify-center backdrop-blur-sm bg-black bg-opacity-30 z-40">
          <div class="relative bg-white dark:bg-gray-800 dark:text-white rounded-lg border-2 border-black p-8 w-96 shadow-lg">
            <div id="dropzoneContainer" class="flex flex-col items-center justify-center">
              <label for="dropzone-file" class="flex flex-col items-center justify-center w-full h-64 bg-gray-50 dark:bg-gray-700 border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-lg cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-600 transition">
                <div class="flex flex-col items-center justify-center pt-5 pb-6">
                  <svg class="w-8 h-8 mb-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h3a3 3 0 0 0 0-6h-.025a5.56 5.56 0 0 0 .025-.5A5.5 5.5 0 0 0 7.207 9.021C7.137 9.017 7.071 9 7 9a4 4 0 1 0 0 8h2.167M12 19v-9m0 0-2 2m2-2 2 2"/></svg>
                  <p class="mb-2 text-sm text-gray-700 dark:text-gray-300"><span class="font-semibold">Click to upload</span> or drag and drop</p>
                  <p class="text-xs text-gray-500 dark:text-gray-400">Any file type is accepted (max 10MB)</p>
                </div>
                <input id="dropzone-file" name="file" type="file" class="hidden" />
              </label>
            </div>

            <div id="fileSelectedContainer" class="hidden flex flex-col items-center justify-center">
              <svg class="w-16 h-16 mb-4 text-green-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <p class="mb-4 text-center text-gray-700 dark:text-gray-300">
                <span class="font-semibold text-lg" id="selectedFileName">File selected</span>
              </p>
              <button id="submitBtn" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded-lg transition mb-2">
                Upload File
              </button>
              <button id="cancelBtn" class="w-full bg-gray-400 hover:bg-gray-500 text-white font-bold py-2 px-4 rounded-lg transition">
                Cancel
              </button>
            </div>

            <button id="closeBtn" class="absolute top-2 right-2 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
              <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
        </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.js"></script>
    <script>
      let selectedFile = null;

      const uploadBtn = document.getElementById('uploadBtn');
      const modalBackdrop = document.getElementById('modalBackdrop');
      const closeBtn = document.getElementById('closeBtn');
      const dropzoneFile = document.getElementById('dropzone-file');
      const dropzoneContainer = document.getElementById('dropzoneContainer');
      const fileSelectedContainer = document.getElementById('fileSelectedContainer');
      const selectedFileName = document.getElementById('selectedFileName');
      const submitBtn = document.getElementById('submitBtn');
      const cancelBtn = document.getElementById('cancelBtn');
      const dropzoneLabel = document.querySelector('label[for="dropzone-file"]');
      const fileSearchInput = document.getElementById('fileSearchInput');
      const fileSortSelect = document.getElementById('fileSortSelect');
      const filesTableBody = document.getElementById('filesTableBody');
      const noSearchResultsRow = document.getElementById('noSearchResultsRow');
      const fileRows = filesTableBody ? Array.from(filesTableBody.querySelectorAll('[data-file-row]')) : [];

      uploadBtn.addEventListener('click', () => {
        modalBackdrop.classList.remove('hidden');
        dropzoneContainer.classList.remove('hidden');
        fileSelectedContainer.classList.add('hidden');
        selectedFile = null;
      });

      closeBtn.addEventListener('click', closeModal);
      modalBackdrop.addEventListener('click', (e) => {
        if (e.target === modalBackdrop) {
          closeModal();
        }
      });

      function closeModal() {
        modalBackdrop.classList.add('hidden');
        dropzoneContainer.classList.remove('hidden');
        fileSelectedContainer.classList.add('hidden');
        selectedFile = null;
        dropzoneFile.value = '';
      }

      dropzoneFile.addEventListener('change', (e) => {
        if (e.target.files.length > 0) {
          selectedFile = e.target.files[0];
          showFileSelected();
        }
      });

      dropzoneLabel.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzoneLabel.classList.add('bg-blue-100', 'dark:bg-blue-900');
      });

      dropzoneLabel.addEventListener('dragleave', () => {
        dropzoneLabel.classList.remove('bg-blue-100', 'dark:bg-blue-900');
      });

      dropzoneLabel.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzoneLabel.classList.remove('bg-blue-100', 'dark:bg-blue-900');

        const files = e.dataTransfer.files;
        if (files.length > 0) {
          selectedFile = files[0];
          dropzoneFile.files = files;
          showFileSelected();
        }
      });

      function showFileSelected() {
        dropzoneContainer.classList.add('hidden');
        fileSelectedContainer.classList.remove('hidden');
        selectedFileName.textContent = selectedFile.name;
      }

      function updateFileList() {
        if (!filesTableBody) return;

        const query = fileSearchInput.value.trim().toLowerCase();
        const sortValue = fileSortSelect.value;
        const sortedRows = [...fileRows].sort((a, b) => {
          if (sortValue === 'name') {
            return a.dataset.name.localeCompare(b.dataset.name, undefined, { sensitivity: 'base' });
          }

          if (sortValue === 'size') {
            return Number(a.dataset.size) - Number(b.dataset.size);
          }

          return Number(a.dataset.index) - Number(b.dataset.index);
        });

        let visibleCount = 0;
        sortedRows.forEach((row) => {
          const isMatch = row.dataset.name.toLowerCase().includes(query);
          row.classList.toggle('hidden', !isMatch);
          filesTableBody.appendChild(row);
          if (isMatch) visibleCount += 1;
        });

        filesTableBody.appendChild(noSearchResultsRow);
        noSearchResultsRow.classList.toggle('hidden', visibleCount > 0);
      }

      if (fileSearchInput && fileSortSelect) {
        fileSearchInput.addEventListener('input', updateFileList);
        fileSortSelect.addEventListener('change', updateFileList);
      }

      async function uploadFile() {
        if (!selectedFile) return;

        const formData = new FormData();
        formData.append('file', selectedFile);

        try {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Uploading...';

          const response = await fetch('/upload', {
            method: 'POST',
            body: formData,
          });

          if (response.ok) {
            window.location.reload();
          } else {
            const errorText = await response.text();
            alert('Upload failed: ' + errorText);
          }
        } catch (error) {
          console.error('Upload error:', error);
          alert('Error uploading file. Please try again.');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Upload File';
        }
      }

      submitBtn.addEventListener('click', uploadFile);
      cancelBtn.addEventListener('click', closeModal);

      async function deleteFile(fileId) {
        if (!confirm('Delete this file?')) return;

        try {
          const response = await fetch(`/file/${fileId}`, {
            method: 'DELETE',
          });

          if (response.ok) {
            window.location.reload();
          } else {
            const json = await response.json();
            alert('Delete failed: ' + (json.message || 'Unknown error'));
          }
        } catch (error) {
          console.error('Delete error:', error);
          alert('Error deleting file. Please try again.');
        }
      }
    </script>
  </body>
</html>
